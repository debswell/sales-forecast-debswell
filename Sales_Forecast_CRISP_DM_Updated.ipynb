## 4. Modeling
### Import Libraries
```python
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.model_selection import train_test_split
from sklearn.ensemble import RandomForestRegressor
from xgboost import XGBRegressor
from sklearn.metrics import mean_squared_error, mean_absolute_error, r2_score
from sklearn.model_selection import early_stopping
```

### Load Data
```python
dataset = pd.read_csv('sales_data.csv')  # Replace with your data source
```

### 60-20-20 Train-Validation-Test Split
```python
train_data, temp_data = train_test_split(dataset, test_size=0.4, random_state=42)
val_data, test_data = train_test_split(temp_data, test_size=0.5, random_state=42)
```

### Model Training
#### Random Forest Model
```python
X_train = train_data.drop('target', axis=1)
y_train = train_data['target']

rf_model = RandomForestRegressor(n_estimators=100, random_state=42)
rf_model.fit(X_train, y_train)
```

#### XGBoost Model with Early Stopping
```python
X_val = val_data.drop('target', axis=1)
y_val = val_data['target']

xgb_model = XGBRegressor(n_estimators=1000, random_state=42)

xgb_model.fit(X_train, y_train, eval_set=[(X_val, y_val)], early_stopping_rounds=10, verbose=False)
```

## 5. Evaluation
### Metrics Calculation
```python
# Predictions
val_predictions_rf = rf_model.predict(X_val)
test_predictions_rf = rf_model.predict(test_data.drop('target', axis=1))

val_predictions_xgb = xgb_model.predict(X_val)
test_predictions_xgb = xgb_model.predict(test_data.drop('target', axis=1))

# Calculate Metrics
metrics = {
    'RandomForest': {
        'MSE': mean_squared_error(y_val, val_predictions_rf),
        'MAE': mean_absolute_error(y_val, val_predictions_rf),
        'R^2': r2_score(y_val, val_predictions_rf)
    },
    'XGBoost': {
        'MSE': mean_squared_error(y_val, val_predictions_xgb),
        'MAE': mean_absolute_error(y_val, val_predictions_xgb),
        'R^2': r2_score(y_val, val_predictions_xgb)
    }
}
```  

### Results
```python
# Print Results
print(metrics) 
```

### Visualizations
```python
plt.figure(figsize=(14, 7))
plt.subplot(1, 2, 1)
sns.histplot(val_predictions_rf, kde=True, color='blue', label='Random Forest Predictions')
plt.title('Random Forest Predictions Distribution')

plt.subplot(1, 2, 2)
sns.histplot(val_predictions_xgb, kde=True, color='green', label='XGBoost Predictions')
plt.title('XGBoost Predictions Distribution')
plt.show()
```

