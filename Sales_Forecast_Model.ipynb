# Sales Forecast Model

## 1. Import Necessary Libraries
import pandas as pd  
import numpy as np  
import matplotlib.pyplot as plt  
import seaborn as sns  
from sklearn.ensemble import RandomForestRegressor  
from sklearn.model_selection import train_test_split  
from sklearn.metrics import mean_squared_error, r2_score  
import xgboost as xgb  

## 2. Load the Dataset
# Update with the correct path to your dataset
data = pd.read_csv('path_to_your_sales_data.csv')  

## 3. Data Analysis
# Overview of data
data.head()  
data.info()  
data.describe()  

# Check for missing values
missing_values = data.isnull().sum()  
print(missing_values[missing_values > 0])  

# Visualizing data distribution
plt.figure(figsize=(12, 6))  
sns.histplot(data['sales'], bins=30, kde=True)  
plt.title('Sales Distribution')  
plt.xlabel('Sales')  
plt.ylabel('Frequency')  
plt.show()  

## 4. Data Preprocessing
# Convert date columns to datetime format
data['date'] = pd.to_datetime(data['date'])  

# Feature engineering: extract month
data['month'] = data['date'].dt.month  

# (Additional preprocessing steps as necessary)

## 5. Train/Test/Validation Split
# Splitting by months
train_data = data[data['date'] < '2025-01-01']  
validation_data = data[(data['date'] >= '2025-01-01') & (data['date'] < '2025-07-01')]  
test_data = data[data['date'] >= '2025-07-01']  

# Features and target variable
X_train = train_data.drop(['sales', 'date'], axis=1)  
y_train = train_data['sales']  
X_val = validation_data.drop(['sales', 'date'], axis=1)  
y_val = validation_data['sales']  
X_test = test_data.drop(['sales', 'date'], axis=1)  
y_test = test_data['sales']  

## 6. Model Building
### Random Forest Model
rf_model = RandomForestRegressor(n_estimators=100, random_state=42)  
rf_model.fit(X_train, y_train)  
predictions_rf = rf_model.predict(X_val)  

# Evaluation
rmse_rf = np.sqrt(mean_squared_error(y_val, predictions_rf))  
r2_rf = r2_score(y_val, predictions_rf)  
print(f"Random Forest RMSE: {rmse_rf}")  
print(f"Random Forest R²: {r2_rf}")  

### XGBoost Model
xgb_model = xgb.XGBRegressor(random_state=42)  
xgb_model.fit(X_train, y_train)  
predictions_xgb = xgb_model.predict(X_val)  

# Evaluation
rmse_xgb = np.sqrt(mean_squared_error(y_val, predictions_xgb))  
r2_xgb = r2_score(y_val, predictions_xgb)  
print(f"XGBoost RMSE: {rmse_xgb}")  
print(f"XGBoost R²: {r2_xgb}")  

## 7. Visualizations
# Feature Importance for Random Forest
plt.figure(figsize=(12, 6))  
sns.barplot(x=rf_model.feature_importances_, y=X_train.columns)  
plt.title('Feature Importance - Random Forest')  
plt.show()  

# Predictions vs Actual for Random Forest
plt.figure(figsize=(10, 6))  
plt.scatter(y_val, predictions_rf)  
plt.xlabel('Actual Sales')  
plt.ylabel('Predicted Sales')  
plt.title('Random Forest: Predictions vs Actual')  
plt.show()  

